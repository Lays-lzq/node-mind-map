{
    "name": "node-mind-map",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite --host --mode development --open",
        "prod": "vite --host --mode production --open",
        "dev:server": "node --watch server/index.js",
        "db:up": "docker compose up -d mysql",
        "db:pull": "docker compose pull mysql",
        "db:down": "docker compose down",
        "db:init": "node server/scripts/init-db.js",
        "db:setup": "npm run db:up && node server/scripts/wait-for-mysql.js && npm run db:init",
        "build": "vite build --mode production",
        "preview": "vite preview --open --host",
        "lint": "eslint --ext .js,.ts,.vue src/"
    },
    "dependencies": {
        "@element-plus/icons-vue": "^2.3.1",
        "cors": "^2.8.5",
        "dompurify": "^3.4.11",
        "dotenv": "^16.4.7",
        "element-plus": "2.11.3",
        "express": "^4.21.2",
        "konva": "^9.2.2",
        "marked": "^18.0.5",
        "mysql2": "^3.12.0",
        "openai": "^6.45.0",
        "vue": "^3.4.21",
        "vue-konva": "3.0.2",
        "vue-router": "^4.3.0"
    },
    "devDependencies": {
        "@types/dompurify": "^3.0.5",
        "@types/node": "^18.19.20",
        "@vitejs/plugin-vue": "^5.2.4",
        "@vue/compiler-sfc": "^3.4.21",
        "sass": "^1.89.1",
        "typescript": "^4.9.5",
        "unplugin-auto-import": "^0.17.5",
        "unplugin-vue-components": "^32.1.0",
        "vite": "^5.1.4"
    },
    "engines": {
        "node": ">=16.0.0"
    }
}
